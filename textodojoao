Banco de Dados
Banco relacional com suporte forte:
PostgreSQL (recomendado) ou
SQL Server / MySQL / MariaDB.
Esquema de Banco de Dados
Tabela: teams (equipes)
CREATE TABLE teams (
    id UUID PRIMARY KEY,
    name TEXT NOT NULL,
    created_at TIMESTAMP NOT NULL,
    updated_at TIMESTAMP NOT NULL
);


Tabela: users (usuários)
CREATE TABLE users (
    id UUID PRIMARY KEY,
    name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    password_hash TEXT,
    role TEXT CHECK (role IN ('USER','MANAGER','ADMIN')),
    team_id UUID REFERENCES teams(id),
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP NOT NULL,
    updated_at TIMESTAMP NOT NULL
);


Tabela: tasks (tarefas)
CREATE TABLE tasks (
    id UUID PRIMARY KEY,
    title TEXT NOT NULL,
    description TEXT,
    cod_uor INT,
    tipo_task_id INT,
    etapa_id INT,
    team_id UUID REFERENCES teams(id),
    status TEXT CHECK (status IN 
        ('NOT_STARTED','IN_PROGRESS','PAUSED','COMPLETED','CANCELLED')
    ),
    created_by_user_id UUID REFERENCES users(id),
    created_at TIMESTAMP NOT NULL,
    updated_at TIMESTAMP NOT NULL
);


Tabela: task_user_assignments (tarefa ↔ usuário)
CREATE TABLE task_user_assignments (
    id UUID PRIMARY KEY,
    task_id UUID REFERENCES tasks(id),
    user_id UUID REFERENCES users(id),
    assigned_at TIMESTAMP NOT NULL,
    is_active BOOLEAN DEFAULT TRUE
);


Tabela: tipo_task (pool de tipos de tarefas)
CREATE TABLE tipo_task (
    id INT PRIMARY KEY,
    etapa_id INT NOT NULL
);


Tabela: timer_events (logs de ações do cronômetro)
CREATE TABLE timer_events (
    id UUID PRIMARY KEY,
    task_id UUID REFERENCES tasks(id),
    user_id UUID REFERENCES users(id),
    session_id UUID,
    event_type TEXT CHECK (event_type IN 
        ('START','PAUSE','RESUME','STOP','COMPLETE')
    ),
    occurred_at TIMESTAMP NOT NULL,
    metadata JSONB
);


Tabela: task_time_summary (estado de tempo por usuário)
CREATE TABLE task_time_summary (
    id UUID PRIMARY KEY,
    task_id UUID REFERENCES tasks(id),
    user_id UUID REFERENCES users(id),
    accumulated_seconds BIGINT DEFAULT 0,
    current_state TEXT CHECK (current_state IN 
        ('IDLE','RUNNING','PAUSED','COMPLETED')
    ),
    last_event_id UUID REFERENCES timer_events(id),
    last_event_at TIMESTAMP
);


